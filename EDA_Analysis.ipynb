"""
Retail Lead Conversion & Operational Efficiency Analysis
This script performs Data Preprocessing, Feature Engineering, and 
Exploratory Data Analysis (EDA) on retail sales lead data.
"""

import pandas as pd
import numpy as np

# ==========================================
# Phase 1: Data Loading & Preprocessing
# ==========================================
print("--- Phase 1: Data Loading & Preprocessing ---")

# Load the dataset
# Note: Ensure the CSV file is in the same directory as this script
file_path = "Cleaned_Retail_Leads_Data.csv" 
try:
    df = pd.read_csv(file_path)
    print(f"Dataset loaded successfully with {df.shape[0]} rows and {df.shape[1]} columns.\n")
except FileNotFoundError:
    print("Error: Please rename your raw file to 'Cleaned_Retail_Leads_Data.csv' and place it in the same folder.\n")

# Convert date columns to datetime objects for accurate time calculations
date_cols = ['Lead Date', 'Pre-Booking Date', 'Booking Date', 'Delivery Date', 'Service Follow-up Date']
for col in date_cols:
    df[col] = pd.to_datetime(df[col], errors='coerce')

# Fix Data Integrity: Handle records marked as 'Delivered' but also 'Cancelled' (Returns)
df['Final Status'] = np.where(
    df['Delivery Date'].notnull() & (df['Cancellation Status'] == 'Yes'), 'Returned',
    np.where(df['Cancellation Status'] == 'Yes', 'Cancelled',
    np.where(df['Delivery Date'].notnull(), 'Delivered', 'In Pipeline'))
)

# ==========================================
# Phase 2: Feature Engineering
# ==========================================
print("--- Phase 2: Feature Engineering ---")

# 1. Categorize Net Promoter Score (NPS)
def categorize_nps(rating):
    if pd.isna(rating):
        return 'Unknown'
    if rating >= 9:
        return 'Promoter'
    elif rating >= 7:
        return 'Passive'
    else:
        return 'Detractor'

df['NPS Category'] = df['Customer Rating'].apply(categorize_nps)

# 2. Validate Turnaround Time (TAT)
# Recalculating to ensure data quality
df['Calculated TAT (Lead to Delivery)'] = (df['Delivery Date'] - df['Lead Date']).dt.days

print("Feature engineering complete. New columns added: 'Final Status', 'NPS Category', 'Calculated TAT'.\n")

# ==========================================
# Phase 3: Exploratory Data Analysis (EDA)
# ==========================================
print("--- Phase 3: Exploratory Data Analysis (EDA) ---")

# --- 1. Conversion Funnel Analysis ---
total_leads = len(df)
pre_bookings = df['Pre-Booking Date'].notnull().sum()
bookings = df['Booking Date'].notnull().sum()
deliveries = df['Delivery Date'].notnull().sum()

conversion_data = {
    'Stage': ['1. Lead', '2. Pre-Booking', '3. Booking', '4. Delivery'],
    'Volume': [total_leads, pre_bookings, bookings, deliveries],
    'Absolute Conversion (%)': [100, (pre_bookings/total_leads)*100, (bookings/total_leads)*100, (deliveries/total_leads)*100]
}
conversion_df = pd.DataFrame(conversion_data)
print("1. Conversion Funnel:")
print(conversion_df.to_string(index=False))
print("-" * 40)

# --- 2. NPS Calculation by Store ---
# Formula: NPS = % Promoters - % Detractors
nps_stats = df[df['NPS Category'] != 'Unknown'].groupby(['Store Name', 'NPS Category']).size().unstack(fill_value=0)
nps_stats['Total Rated'] = nps_stats['Promoter'] + nps_stats['Passive'] + nps_stats['Detractor']
nps_stats['NPS Score'] = ((nps_stats['Promoter'] - nps_stats['Detractor']) / nps_stats['Total Rated']) * 100

print("2. Net Promoter Score (NPS) by Store:")
print(nps_stats[['NPS Score']].round(2).sort_values(by='NPS Score', ascending=False))
print("-" * 40)

# --- 3. Operational Bottlenecks (Average TAT by Store) ---
tat_cols = ['TAT Pre-Booking (Days)', 'TAT Booking (Days)', 'TAT Delivery (Days)']
avg_tat_per_store = df.groupby('Store Name')[tat_cols].mean().round(2).reset_index()

print("3. Average Turnaround Time (TAT) in Days:")
print(avg_tat_per_store.to_string(index=False))
print("-" * 40)

# --- 4. Cancellation Analysis (Lost Revenue) ---
cancellations = df[df['Cancellation Status'] == 'Yes']
top_cancellation_reasons = cancellations['Cancellation Reason'].value_counts(normalize=True).mul(100).round(1).reset_index()
top_cancellation_reasons.columns = ['Reason', 'Percentage (%)']

print("4. Top Cancellation Reasons:")
print(top_cancellation_reasons.head())
print("-" * 40)

# ==========================================
# Phase 4: Executive Summary Output
# ==========================================
print("--- Executive Summary Insights ---")
print(f"-> The overall conversion rate from Lead to Delivery is {(deliveries/total_leads)*100:.1f}%.")
print(f"-> A major drop-off occurs early: {((total_leads-pre_bookings)/total_leads)*100:.1f}% of leads are lost before Pre-Booking.")
print(f"-> System-wide NPS is critically low. The highest performing store is Chennai MBC with an NPS of {nps_stats.loc['Chennai MBC', 'NPS Score']:.1f}.")
print(f"-> {len(df[df['Final Status'] == 'Returned'])} items were marked as Delivered but later Cancelled, indicating post-sales issues.")
